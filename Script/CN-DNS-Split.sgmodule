#!name=CN DNS Split
#!desc=Use 223.5.5.5 for CN domains and A-only DoH for other domains. Run cn-dns-update once after installing.
#!system=ios

[Script]
cn-dns-update = type=cron,cronexp="15 3 * * 1",script-path=https://raw.githubusercontent.com/Reukix/ukix/refs/heads/main/Script/CN-DNS-Update.js,argument=source=https%3A%2F%2Fraw.githubusercontent.com%2FReukix%2Fukix%2Frefs%2Fheads%2Fmain%2FRule%2FCN.list&fpr=0.000001&notify=1,engine=webview,timeout=120
dns cn-dns-split script-path=https://raw.githubusercontent.com/Reukix/ukix/refs/heads/main/Script/CN-DNS-Split.js,argument=cnDns=223.5.5.5&doh=https%3A%2F%2F1.1.1.1%2Fdns-query%2Chttps%3A%2F%2F8.8.8.8%2Fdns-query&ttl=60&timeout=2&fallback=1,engine=jsc,timeout=5

[Host]
* = script:cn-dns-split
